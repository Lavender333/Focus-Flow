# GEMINI_API_KEY: Required for Gemini AI API calls.
# Set this in your local environment or deployment secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# Set this to your deployed application URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL=
APP_URL="MY_APP_URL"

# Supabase: Required for database and authentication.
# Found in Project Settings > API in your Supabase dashboard.
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-public-key"
